@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["HideNavbar"] = true;
}

<div class="splash-page">
    <img src="~/images/logo.png" class="brand-logo" alt="V Car Rentals Logo" />
    <p class="brand-name">Car Rentals</p>
    <div class="mt-4 d-flex gap-3">
        <a href="/Register" class="btn btn-outline-primary px-4 rounded-pill">Sign Up</a>
        <a href="/Login" class="btn btn-outline-primary px-4 rounded-pill">Sign In</a>
    </div>
</div>
