@page
@model VentureCarRentals.Pages.Admin.Users.UserControlModel
@{
    ViewData["Title"] = "Users";
    Layout = "_Layout";
}

<div class="row g-4">

    <div class="col-lg-3">
        <div class="dashboard-header mb-3">
            <h5>User Statistics</h5>
            <p>@DateTime.Now.ToString("ddd, dd MMMM, yyyy, hh:mm tt")</p>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between">
                <span>Total Users</span>
                <small>All</small>
            </div>
            <h3>@Model.TotalUsers</h3>
            <p>Registered customer accounts</p>
            <strong>Users <span>@Model.TotalUsers</span></strong>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between">
                <span>Verified</span>
                <small>Approved</small>
            </div>
            <h3>@Model.VerifiedUsers</h3>
            <p>Users allowed to book cars</p>
            <strong>Verified <span>@Model.VerifiedUsers</span></strong>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between">
                <span>Pending</span>
                <small>Review</small>
            </div>
            <h3>@Model.PendingUsers</h3>
            <p>Users waiting for document approval</p>
            <strong>Pending <span>@Model.PendingUsers</span></strong>
        </div>

        <div class="stat-card">
            <div class="d-flex justify-content-between">
                <span>Incomplete</span>
                <small>Missing</small>
            </div>
            <h3>@Model.IncompleteUsers</h3>
            <p>Users missing profile or documents</p>
            <strong>Incomplete <span>@Model.IncompleteUsers</span></strong>
        </div>
    </div>

    <div class="col-lg-9">

        <div class="topbar mb-4">
            <div></div>
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-bell-fill notification-icon"></i>
                <div class="search-box">
                    <input type="text" placeholder="Search users">
                    <i class="bi bi-search"></i>
                </div>
            </div>
        </div>

        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h6 class="mb-0">Registered Users</h6>
                    <span class="text-muted small">Showing @Model.Users.Count user(s)</span>
                </div>

                <a asp-page="/Admin/Documents/Verification" class="btn add-car-btn">
                    <i class="bi bi-file-earmark-check"></i> Verify Documents
                </a>
            </div>

            <div class="table-responsive">
                <table class="table align-middle admin-table">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Documents</th>
                            <th>Status</th>
                            <th>Registered</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Users.Any())
                        {
                            var count = 1;

                            foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td>@count.ToString("00")</td>

                                    <td>
                                        <strong>@user.FullName</strong>
                                        <br />
                                        <small class="text-muted">@user.Country</small>
                                    </td>

                                    <td>@user.Email</td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(user.PhoneNumber))
                                        {
                                            @user.PhoneNumber
                                        }
                                        else
                                        {
                                            <span class="text-muted">No phone</span>
                                        }
                                    </td>

                                    <td>@user.DocumentCount document(s)</td>

                                    <td>
                                        @if (user.VerificationStatus == "Verified")
                                        {
                                            <span class="badge bg-success">Verified</span>
                                        }
                                        else if (user.VerificationStatus == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else if (user.VerificationStatus == "Rejected")
                                        {
                                            <span class="badge bg-danger">Rejected</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Incomplete</span>
                                        }
                                    </td>

                                    <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>

                                    <td>
                                        <a asp-page="/Admin/Documents/Verification"
                                           asp-route-UserId="@user.UserId"
                                           class="details-btn">
                                            View
                                        </a>
                                    </td>
                                </tr>

                                count++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    No users found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>