@page
@model VentureCarRentals.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <h4>Manage Cars</h4>
            <p>Add, edit, delete, and update car status.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <h4>Bookings</h4>
            <p>Monitor customer bookings.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <h4>Reports</h4>
            <p>View booking and revenue reports.</p>
        </div>
    </div>
</div>