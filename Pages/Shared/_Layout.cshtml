<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Venture Car Rentals</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VentureCarRentals.styles.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["HideNavbar"] == null || !(bool)ViewData["HideNavbar"])
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                        <img src="~/images/logo.png" height="36" alt="Logo" />
                        <span class="fw-bold text-secondary" style="letter-spacing:0.1em;">CAR RENTALS</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Index">Home</a>
                            </li>

                            @{
                                var user = Context.Session.GetString("UserName");
                            }

                            @if (!string.IsNullOrEmpty(user))
                            {
                                <li class="nav-item">
                                    <span class="nav-link">Hello, @user</span>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-danger" asp-page="/Logout">Logout</a>
                                </li>
                            }

                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="@(ViewData["HideNavbar"] != null && (bool)ViewData["HideNavbar"] ? "" : "container")">
        <main role="main" class="pb-0">
            @RenderBody()
        </main>
    </div>

    @if (ViewData["HideNavbar"] == null || !(bool)ViewData["HideNavbar"])
    {
        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - VentureCarRentals - <a asp-area="" asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
