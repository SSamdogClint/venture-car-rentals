@page
@model VentureCarRentals.Pages.User.HomeModel
@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<div class="user-wrapper">

    @await Html.PartialAsync("/Pages/User/_UserSidebar.cshtml")

    <main class="user-main">

        <div class="user-topbar">
            <button type="button" class="user-menu-btn" onclick="toggleUserSidebar()">
                <i class="bi bi-list"></i>
            </button>

            <i class="bi bi-bell notification-bell"></i>
        </div>

        <section class="booking-hero">
            <h1>Start Your Booking Now</h1>

            <div class="booking-card">
                <form method="get" asp-page="/User/Cars/BrowseCars">
                    <div class="row g-4">

                        <div class="col-md-6">
                            <label class="form-label">Borrow Date</label>
                            <div class="user-input-card">
                                <input type="date"
                                       name="BorrowDate"
                                       value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       required />
                                <i class="bi bi-calendar-event"></i>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Borrow Time</label>
                            <div class="user-input-card">
                                <input type="time"
                                       name="BorrowTime"
                                       value="08:00"
                                       required />
                                <i class="bi bi-clock"></i>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Return Date</label>
                            <div class="user-input-card">
                                <input type="date"
                                       name="ReturnDate"
                                       value="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                                       required />
                                <i class="bi bi-calendar-event"></i>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Return Time</label>
                            <div class="user-input-card">
                                <input type="time"
                                       name="ReturnTime"
                                       value="17:00"
                                       required />
                                <i class="bi bi-clock"></i>
                            </div>
                        </div>

                        <div class="col-12 text-center">
                            <button type="submit" class="find-car-btn">
                                Find Available Cars
                            </button>
                        </div>

                    </div>
                </form>
            </div>
        </section>

        <section class="review-section">
            <h2>What our customers are saying about Car Rentals</h2>

            <div class="row g-4 mt-2">

                <div class="col-lg-3 col-md-6">
                    <div class="review-card">
                        <div class="stars">
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                        </div>

                        <h5>Review title</h5>
                        <p>Review body</p>

                        <div class="reviewer">
                            <img src="https://i.pravatar.cc/60?img=1" alt="Reviewer" />
                            <div>
                                <strong>Reviewer name</strong>
                                <small>Date</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="review-card">
                        <div class="stars">
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                        </div>

                        <h5>Review title</h5>
                        <p>Review body</p>

                        <div class="reviewer">
                            <img src="https://i.pravatar.cc/60?img=2" alt="Reviewer" />
                            <div>
                                <strong>Reviewer name</strong>
                                <small>Date</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="review-card">
                        <div class="stars">
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                        </div>

                        <h5>Review title</h5>
                        <p>Review body</p>

                        <div class="reviewer">
                            <img src="https://i.pravatar.cc/60?img=3" alt="Reviewer" />
                            <div>
                                <strong>Reviewer name</strong>
                                <small>Date</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="review-card">
                        <div class="stars">
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                            <i class="bi bi-star"></i>
                        </div>

                        <h5>Review title</h5>
                        <p>Review body</p>

                        <div class="reviewer">
                            <img src="https://i.pravatar.cc/60?img=4" alt="Reviewer" />
                            <div>
                                <strong>Reviewer name</strong>
                                <small>Date</small>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </main>

</div>

@if (TempData["VerificationSubmitted"] != null)
{
    <div class="modal fade" id="verificationSubmittedModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content verification-modal">
                <div class="modal-header">
                    <h5 class="modal-title">Verification Submitted</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center">
                    <i class="bi bi-check-circle verification-icon"></i>

                    <h5 class="mt-3">Thank you for your verification</h5>

                    <p class="text-muted">
                        Your account requirements have been submitted successfully.
                        Please wait for 30 minutes to 1 day while the admin reviews and confirms your account verification.
                    </p>
                </div>

                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">
                        Okay
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (TempData["VerificationSubmitted"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const modalElement = document.getElementById("verificationSubmittedModal");

                if (modalElement) {
                    const modal = new bootstrap.Modal(modalElement);
                    modal.show();
                }
            });
        </script>
    }
}