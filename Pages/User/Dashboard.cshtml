@page
@model VentureCarRentals.Pages.User.DashboardModel
@{
    ViewData["Title"] = "User Dashboard";
}

<h1>User Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <h4>Browse Cars</h4>
            <p>View available rental cars.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <h4>My Bookings</h4>
            <p>Check your booking history.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <h4>Documents</h4>
            <p>Upload required rental documents.</p>
        </div>
    </div>
</div>