@page
@model VentureCarRentals.Pages.User.Cars.BrowseCarsModel
@{
    ViewData["Title"] = "Browse Cars";
    Layout = "_Layout";
}

<div class="user-wrapper">

    @await Html.PartialAsync("/Pages/User/_UserSidebar.cshtml")

    <main class="user-main">

        <div class="user-topbar">
            <div class="d-flex align-items-center gap-3">
                <button type="button" class="user-menu-btn" onclick="toggleUserSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <a asp-page="/User/Home" class="back-link">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

            <i class="bi bi-bell notification-bell"></i>
        </div>

        <section class="available-cars-section">

            <h3>@Model.PageHeading</h3>
            <hr />

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @Model.ErrorMessage
                </div>
            }
            else
            {
                @if (Model.IsSearchMode)
                {
                    <div class="selected-date-box mb-3">
                        <strong>Borrow:</strong> @Model.BorrowDateTime.ToString("MMM dd, yyyy hh:mm tt")
                        <span class="mx-2">|</span>
                        <strong>Return:</strong> @Model.ReturnDateTime.ToString("MMM dd, yyyy hh:mm tt")
                    </div>
                }
                else
                {
                    <div class="selected-date-box mb-3">
                        Showing popular cars. Select a borrow and return schedule from the home page to check exact availability.
                    </div>
                }

                @if (Model.Cars.Any())
                {
                    foreach (var car in Model.Cars)
                    {
                        var totalPrice = Model.IsSearchMode
                        ? Model.TotalDays * car.PricePerDay
                        : car.PricePerDay;

                        <div class="vehicle-card">

                            <div class="vehicle-image-box">
                                @if (!string.IsNullOrWhiteSpace(car.ImageUrl))
                                {
                                    <img src="@car.ImageUrl" alt="@car.Make @car.Model" />
                                }
                                else
                                {
                                    <div class="vehicle-no-image">
                                        <i class="bi bi-car-front"></i>
                                        <span>No Image</span>
                                    </div>
                                }

                                <div class="rating-box">
                                    <i class="bi bi-star"></i>
                                    <i class="bi bi-star"></i>
                                    <i class="bi bi-star"></i>
                                    <i class="bi bi-star"></i>
                                    <i class="bi bi-star"></i>
                                    <small>0 Ratings</small>
                                </div>
                            </div>

                            <div class="vehicle-info">
                                <h5>@car.Make @car.Model - @car.Category</h5>

                                <div class="vehicle-features">
                                    <p><i class="bi bi-calendar"></i> @car.Year Model</p>
                                    <p><i class="bi bi-people"></i> @car.Seats Seats</p>
                                    <p><i class="bi bi-gear"></i> @car.Transmission</p>
                                    <p><i class="bi bi-check-circle"></i> @car.Status</p>
                                    <p><i class="bi bi-snow"></i> Airconditioning</p>
                                    <p><i class="bi bi-steering-wheel"></i> Power Steering</p>
                                </div>
                            </div>

                            <div class="vehicle-price">
                                <h4>₱@car.PricePerDay.ToString("N2") <span>/ day</span></h4>

                                @if (Model.IsSearchMode)
                                {
                                    <p>
                                        ₱@totalPrice.ToString("N2") total for<br />
                                        @Model.TotalDays day(s)
                                    </p>

                                    <small>Excl. taxes & insurance(s)</small>

                                    @if (Model.VerificationStatus == "verified")
                                    {
                                        <a class="book-btn"
                                           asp-page="/User/Cars/Create"
                                           asp-route-carId="@car.CarId"
                                           asp-route-borrowDate="@Model.BorrowDate"
                                           asp-route-borrowTime="@Model.BorrowTime"
                                           asp-route-returnDate="@Model.ReturnDate"
                                           asp-route-returnTime="@Model.ReturnTime">
                                            Book
                                        </a>
                                    }
                                    else if (Model.VerificationStatus == "needs_requirements")
                                    {
                                        <button type="button"
                                                class="book-btn border-0"
                                                data-bs-toggle="modal"
                                                data-bs-target="#verifyAccountModal-@car.CarId">
                                            Book
                                        </button>
                                    }
                                    else if (Model.VerificationStatus == "pending")
                                    {
                                        <button type="button" class="book-btn not-verified-btn border-0" disabled>
                                            Not verified yet
                                        </button>
                                    }
                                    else
                                    {
                                        <a class="book-btn" asp-page="/Login">
                                            Login to Book
                                        </a>
                                    }
                                }
                                else
                                {
                                    <p>Check schedule first to book this car.</p>
                                    <small>Price may vary depending on duration.</small>

                                    <a class="book-btn" asp-page="/User/Home">
                                        Check Availability
                                    </a>
                                }
                            </div>

                        </div>

                        @if (Model.IsSearchMode && Model.VerificationStatus == "needs_requirements")
                        {
                            <div class="modal fade" id="verifyAccountModal-@car.CarId" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content verification-modal">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Verify Account First</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body text-center">
                                            <i class="bi bi-shield-check verification-icon"></i>

                                            <h5 class="mt-3">Account verification required</h5>

                                            <p class="text-muted">
                                                Before booking this car, please complete your renter information and upload the required documents for verification.
                                            </p>
                                        </div>

                                        <div class="modal-footer justify-content-center">
                                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                                                Cancel
                                            </button>

                                            <a class="btn btn-primary"
                                               asp-page="/User/Documents/CompleteRequirements"
                                               asp-route-carId="@car.CarId"
                                               asp-route-borrowDate="@Model.BorrowDate"
                                               asp-route-borrowTime="@Model.BorrowTime"
                                               asp-route-returnDate="@Model.ReturnDate"
                                               asp-route-returnTime="@Model.ReturnTime">
                                                Continue Verification
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="empty-result-box">
                        <i class="bi bi-car-front"></i>

                        @if (Model.IsSearchMode)
                        {
                            <h5>No available cars found</h5>
                            <p>All available cars may already be booked for your selected date and time.</p>
                        }
                        else
                        {
                            <h5>No popular cars found</h5>
                            <p>No available cars have been added yet.</p>
                        }
                    </div>
                }
            }

        </section>

    </main>

</div>