@page
@model VentureCarRentals.Pages.User.Payments.IndexModel
@{
    ViewData["Title"] = "Payment Methods";
    Layout = "_Layout";

    /*
        These values are used by the reusable _AddPaymentModal partial.
        Since this page is only for managing saved cards, there is no booking schedule.
    */
    ViewData["AddCardCarId"] = "";
    ViewData["AddCardBorrowDate"] = "";
    ViewData["AddCardBorrowTime"] = "";
    ViewData["AddCardReturnDate"] = "";
    ViewData["AddCardReturnTime"] = "";
}

<div class="user-wrapper">

    @await Html.PartialAsync("/Pages/User/_UserSidebar.cshtml")

    <main class="user-main">

        <div class="user-topbar">
            <div class="d-flex align-items-center gap-3">
                <button type="button" class="user-menu-btn" onclick="toggleUserSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <a asp-page="/User/Home" class="back-link">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

            <i class="bi bi-bell notification-bell"></i>
        </div>

        <section class="payment-method-section">

            <!-- Page Header -->
            <div class="section-header">
                <div>
                    <h2>Payment Methods</h2>
                    <p class="section-subtitle">
                        View and manage your saved demo payment methods.
                    </p>
                </div>

                <!-- Opens reusable Add Payment Method modal -->
                <button type="button"
                        class="btn btn-primary add-payment-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#addPaymentModal">
                    <i class="bi bi-plus-lg"></i> Add Payment Method
                </button>
            </div>

            <div class="summary-line mb-4"></div>

            <!-- Page Messages -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @Model.ErrorMessage
                </div>
            }

            @if (Model.PaymentMethods.Any())
            {
                <div class="saved-cards-grid">

                    @foreach (var method in Model.PaymentMethods)
                    {
                        /*
                        Card logo selection based on saved card brand.
                        */
                        var logoPath = "";
                        var displayBrand = method.CardBrand;

                        if (method.CardBrand.Equals("MasterCard", StringComparison.OrdinalIgnoreCase))
                        {
                            logoPath = "/images/CardType/MasterCardLogo.png";
                            displayBrand = "MasterCard";
                        }
                        else if (method.CardBrand.Equals("Visa", StringComparison.OrdinalIgnoreCase))
                        {
                            logoPath = "/images/CardType/VisaLogo.svg";
                            displayBrand = "Visa";
                        }
                        else if (method.CardBrand.Equals("JCB", StringComparison.OrdinalIgnoreCase))
                        {
                            logoPath = "/images/CardType/JCBlogo.png";
                            displayBrand = "JCB";
                        }

                        /*
                        Deactivated cards remain visible here because this page is for management.
                        They appear gray but are still clickable so users can activate/delete them.
                        */
                        var isInactive = method.Status == "inactive";
                        var cardBoxClass = isInactive
                        ? "payment-card-box inactive-payment-card"
                        : "payment-card-box";

                        <button type="button"
                                class="payment-card-option card-action-button"
                                data-bs-toggle="modal"
                                data-bs-target="#cardActionModal-@method.UserPaymentMethodId">

                            <div class="@cardBoxClass">

                                <div class="card-brand-row">
                                    @if (!string.IsNullOrWhiteSpace(logoPath))
                                    {
                                        <img src="@logoPath"
                                             alt="@displayBrand Logo"
                                             class="card-brand-logo" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-credit-card-2-front fs-2 text-primary"></i>
                                    }

                                    <span class="card-brand-name">@displayBrand</span>
                                </div>

                                <div class="card-info">
                                    <div class="card-number">
                                        @method.MaskedCardNumber
                                    </div>

                                    <div class="card-holder">
                                        @method.CardHolderName
                                    </div>

                                    <div class="card-expiry">
                                        Expires: @method.ExpiryDate
                                    </div>

                                    @if (isInactive)
                                    {
                                        <div class="card-status inactive-status">Inactive</div>
                                    }
                                    else
                                    {
                                        <div class="card-status active-status">Active</div>
                                    }
                                </div>

                            </div>
                        </button>

                        <!-- Reusable modal for activate/deactivate/delete card actions -->
                        @await Html.PartialAsync("/Pages/User/Payments/_CardActionModal.cshtml", method)
                    }

                </div>
            }
            else
            {
                <div class="empty-payment-state">
                    <i class="bi bi-credit-card-2-front"></i>
                    <h4>No saved payment methods yet</h4>
                    <p>Your saved card will appear here after you add a demo card.</p>
                </div>
            }

        </section>

    </main>
</div>

<!-- Reusable Add Payment Method Modal -->
@await Html.PartialAsync("/Pages/User/Payments/_AddPaymentModal.cshtml")