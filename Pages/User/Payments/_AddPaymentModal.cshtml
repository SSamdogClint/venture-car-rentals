@{
    /*
        This reusable partial is used by both:
        1. Payments/Index.cshtml
        2. Payments/PaymentMethod.cshtml

        The hidden schedule fields are needed only when adding a card during booking payment.
    */
    var carId = ViewData["AddCardCarId"]?.ToString() ?? "";
    var borrowDate = ViewData["AddCardBorrowDate"]?.ToString() ?? "";
    var borrowTime = ViewData["AddCardBorrowTime"]?.ToString() ?? "";
    var returnDate = ViewData["AddCardReturnDate"]?.ToString() ?? "";
    var returnTime = ViewData["AddCardReturnTime"]?.ToString() ?? "";
}

<div class="modal fade" id="addPaymentModal" tabindex="-1" aria-labelledby="addPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content payment-modal">

            <div class="modal-header">
                <h5 class="modal-title" id="addPaymentModalLabel">Add Payment Method</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" asp-page-handler="SaveCard">
                <div class="modal-body">

                    <!-- Demo card preview -->
                    <div class="card-preview-box">
                        <div class="card-preview-top">
                            <div id="cardLogoWrapper" class="card-logo-wrapper d-none">
                                <img id="cardLogoPreview" src="" alt="Card Logo" class="card-preview-logo" />
                            </div>

                            <span id="cardTypePreview" class="card-preview-type">
                                CARD TYPE WILL APPEAR HERE
                            </span>
                        </div>

                        <div class="card-preview-number" id="cardNumberPreview">
                            •••• •••• •••• ••••
                        </div>

                        <div class="card-preview-bottom">
                            <div>
                                <small>Card Holder</small>
                                <div id="cardHolderPreview">FULL NAME</div>
                            </div>

                            <div>
                                <small>Expires</small>
                                <div id="expiryPreview">MM/YY</div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <label for="CardAccountNumber">Card Number</label>
                        <input type="text"
                               id="CardAccountNumber"
                               name="CardAccountNumber"
                               class="form-control"
                               maxlength="19"
                               placeholder="1234 0000 0000 9999"
                               required />
                    </div>

                    <div class="form-group-custom">
                        <label for="CardHolderName">Card Holder Name</label>
                        <input type="text"
                               id="CardHolderName"
                               name="CardHolderName"
                               class="form-control"
                               placeholder="Juan Dela Cruz"
                               required />
                    </div>

                    <div class="form-group-custom">
                        <label for="ExpiryDate">Expiry Date</label>
                        <input type="text"
                               id="ExpiryDate"
                               name="ExpiryDate"
                               class="form-control"
                               maxlength="5"
                               placeholder="MM/YY"
                               required />
                    </div>

                    <input type="hidden" id="DetectedCardType" name="DetectedCardType" />

                    <!-- These values preserve booking schedule when this partial is used in PaymentMethod.cshtml -->
                    <input type="hidden" name="CarId" value="@carId" />
                    <input type="hidden" name="BorrowDate" value="@borrowDate" />
                    <input type="hidden" name="BorrowTime" value="@borrowTime" />
                    <input type="hidden" name="ReturnDate" value="@returnDate" />
                    <input type="hidden" name="ReturnTime" value="@returnTime" />

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-primary">
                        Save Payment Method
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const addPaymentModal = document.getElementById("addPaymentModal");

        const cardNumberInput = document.getElementById("CardAccountNumber");
        const cardHolderInput = document.getElementById("CardHolderName");
        const expiryInput = document.getElementById("ExpiryDate");

        const cardLogoWrapper = document.getElementById("cardLogoWrapper");
        const cardLogoPreview = document.getElementById("cardLogoPreview");
        const cardTypePreview = document.getElementById("cardTypePreview");
        const cardNumberPreview = document.getElementById("cardNumberPreview");
        const cardHolderPreview = document.getElementById("cardHolderPreview");
        const expiryPreview = document.getElementById("expiryPreview");
        const detectedCardType = document.getElementById("DetectedCardType");

        /*
            Detect demo card type using the first 4 digits.
            1234 = MasterCard, 5678 = Visa, 4321 = JCB.
        */
        function detectCardType(firstFourDigits) {
            if (firstFourDigits === "1234") {
                return {
                    type: "MasterCard",
                    logo: "/images/CardType/MasterCardLogo.png"
                };
            }

            if (firstFourDigits === "5678") {
                return {
                    type: "Visa",
                    logo: "/images/CardType/VisaLogo.svg"
                };
            }

            if (firstFourDigits === "4321") {
                return {
                    type: "JCB",
                    logo: "/images/CardType/JCBlogo.png"
                };
            }

            return {
                type: "Unknown",
                logo: ""
            };
        }

        function formatCardNumber(value) {
            const digitsOnly = value.replace(/\D/g, "").slice(0, 16);
            return digitsOnly.replace(/(.{4})/g, "$1 ").trim();
        }

        if (cardNumberInput) {
            cardNumberInput.addEventListener("input", function () {
                const formattedValue = formatCardNumber(this.value);
                this.value = formattedValue;

                const digitsOnly = formattedValue.replace(/\D/g, "");
                const firstFourDigits = digitsOnly.substring(0, 4);
                const result = detectCardType(firstFourDigits);

                cardNumberPreview.textContent = digitsOnly.length > 0
                    ? formattedValue.padEnd(19, "•")
                    : "•••• •••• •••• ••••";

                if (result.type === "Unknown") {
                    cardLogoWrapper.classList.add("d-none");
                    cardLogoPreview.src = "";
                    cardTypePreview.textContent = "CARD TYPE WILL APPEAR HERE";
                    detectedCardType.value = "";
                    return;
                }

                cardLogoWrapper.classList.remove("d-none");
                cardLogoPreview.src = result.logo;
                cardTypePreview.textContent = result.type;
                detectedCardType.value = result.type;
            });
        }

        if (cardHolderInput) {
            cardHolderInput.addEventListener("input", function () {
                cardHolderPreview.textContent = this.value.trim().toUpperCase() || "FULL NAME";
            });
        }

        if (expiryInput) {
            expiryInput.addEventListener("input", function () {
                let value = this.value.replace(/\D/g, "").slice(0, 4);

                if (value.length >= 3) {
                    value = value.slice(0, 2) + "/" + value.slice(2);
                }

                this.value = value;
                expiryPreview.textContent = value || "MM/YY";
            });
        }

        /*
            Clear all modal fields and preview when the modal is closed.
        */
        if (addPaymentModal) {
            addPaymentModal.addEventListener("hidden.bs.modal", function () {
                const form = addPaymentModal.querySelector("form");

                if (form) {
                    form.reset();
                }

                cardLogoWrapper.classList.add("d-none");
                cardLogoPreview.src = "";
                cardTypePreview.textContent = "CARD TYPE WILL APPEAR HERE";
                cardNumberPreview.textContent = "•••• •••• •••• ••••";
                cardHolderPreview.textContent = "FULL NAME";
                expiryPreview.textContent = "MM/YY";
                detectedCardType.value = "";
            });
        }
    });
</script>