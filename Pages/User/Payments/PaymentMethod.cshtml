@page
@model VentureCarRentals.Pages.User.Payments.PaymentMethodModel
@{
    ViewData["Title"] = "Payment Method";
    Layout = "_Layout";

    /*
        These ViewData values are used by the reusable _AddPaymentModal partial.
        In the booking payment page, the modal must preserve the selected booking schedule.
    */
    ViewData["AddCardCarId"] = Model.CarId;
    ViewData["AddCardBorrowDate"] = Model.BorrowDate;
    ViewData["AddCardBorrowTime"] = Model.BorrowTime;
    ViewData["AddCardReturnDate"] = Model.ReturnDate;
    ViewData["AddCardReturnTime"] = Model.ReturnTime;
}

<div class="user-wrapper">

    @await Html.PartialAsync("/Pages/User/_UserSidebar.cshtml")

    <main class="user-main">

        <div class="user-topbar">
            <div class="d-flex align-items-center gap-3">
                <button type="button" class="user-menu-btn" onclick="toggleUserSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <a asp-page="/User/Cars/BrowseCars" class="back-link">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

            <i class="bi bi-bell notification-bell"></i>
        </div>

        <section class="payment-method-section">

            <!-- Page Header -->
            <div class="section-header">
                <div>
                    <h2>Payment Methods</h2>
                    <p class="section-subtitle">
                        Choose a saved card or pay in cash to complete your booking.
                    </p>
                </div>

                <!-- Opens reusable Add Payment Method modal -->
                <button type="button"
                        class="btn btn-primary add-payment-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#addPaymentModal">
                    <i class="bi bi-plus-lg"></i> Add Payment Method
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @Model.ErrorMessage
                </div>
            }

            @if (Model.Car != null)
            {
                <!-- Booking summary shown before final payment confirmation -->
                <div class="booking-summary-card">
                    <div class="summary-left">
                        <h3>@Model.Car.Make @Model.Car.Model</h3>

                        <p>
                            @Model.Car.Category • @Model.Car.Transmission • @Model.Car.Seats seats
                        </p>

                        <p>
                            <strong>Borrow:</strong>
                            @Model.BorrowDateTime.ToString("MMM dd, yyyy hh:mm tt")
                        </p>

                        <p>
                            <strong>Return:</strong>
                            @Model.ReturnDateTime.ToString("MMM dd, yyyy hh:mm tt")
                        </p>
                    </div>

                    <div class="summary-right">
                        <span class="summary-label">Total Amount</span>
                        <h3>₱@Model.TotalPrice.ToString("N2")</h3>
                    </div>
                </div>

                <form method="post" asp-page-handler="CompleteBooking" class="complete-booking-form">

                    <input type="hidden" asp-for="CarId" />
                    <input type="hidden" asp-for="BorrowDate" />
                    <input type="hidden" asp-for="BorrowTime" />
                    <input type="hidden" asp-for="ReturnDate" />
                    <input type="hidden" asp-for="ReturnTime" />

                    <!-- Cash payment option -->
                    <div class="payment-methods-inline">
                        <label class="payment-inline-option">
                            <input type="radio"
                                   asp-for="SelectedPaymentType"
                                   value="Cash"
                                   checked
                                   onclick="clearSelectedCard()" />

                            <div class="payment-inline-box">
                                <i class="bi bi-cash-stack"></i>

                                <div>
                                    <h5>Cash</h5>
                                    <p>Pay at pickup or at the rental office.</p>
                                </div>
                            </div>
                        </label>
                    </div>

                    <div class="saved-card-header">
                        <h5>Saved Cards</h5>
                        <small>
                            Active cards can be selected. Inactive cards are shown but cannot be used for payment.
                        </small>
                    </div>

                    @if (Model.SavedCards.Any())
                    {
                        <div class="saved-cards-grid">

                            @foreach (var card in Model.SavedCards)
                            {
                                var logoPath = "";
                                var displayBrand = card.CardType;

                                if (card.CardType.Equals("MasterCard", StringComparison.OrdinalIgnoreCase))
                                {
                                    logoPath = "/images/CardType/MasterCardLogo.png";
                                    displayBrand = "MasterCard";
                                }
                                else if (card.CardType.Equals("Visa", StringComparison.OrdinalIgnoreCase))
                                {
                                    logoPath = "/images/CardType/VisaLogo.svg";
                                    displayBrand = "Visa";
                                }
                                else if (card.CardType.Equals("JCB", StringComparison.OrdinalIgnoreCase))
                                {
                                    logoPath = "/images/CardType/JCBlogo.png";
                                    displayBrand = "JCB";
                                }

                                /*
                                Inactive cards are visible but not clickable/selectable here.
                                This prevents users from using deactivated payment methods for booking.
                                */
                                var isInactive = card.Status == "inactive";
                                var cardBoxClass = isInactive
                                ? "payment-card-box inactive-payment-card"
                                : "payment-card-box";

                                if (isInactive)
                                {
                                    <div class="payment-card-option disabled-card-option">
                                        <div class="@cardBoxClass">
                                            <div class="card-brand-row">
                                                @if (!string.IsNullOrWhiteSpace(logoPath))
                                                {
                                                    <img src="@logoPath"
                                                         alt="@displayBrand Logo"
                                                         class="card-brand-logo" />
                                                }
                                                else
                                                {
                                                    <i class="bi bi-credit-card-2-front fs-2 text-primary"></i>
                                                }

                                                <span class="card-brand-name">@displayBrand</span>
                                            </div>

                                            <div class="card-info">
                                                <div class="card-number">@card.MaskedCardNumber</div>
                                                <div class="card-holder">@card.CardHolderName</div>
                                                <div class="card-expiry">Expires: @card.ExpiryDate</div>
                                                <div class="card-status inactive-status">Inactive</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <label class="payment-card-option">
                                        <input type="radio"
                                               name="SelectedSavedCardId"
                                               value="@card.PaymentMethodId"
                                               class="payment-card-radio"
                                               onclick="selectSavedCard()" />

                                        <div class="@cardBoxClass">
                                            <div class="card-brand-row">
                                                @if (!string.IsNullOrWhiteSpace(logoPath))
                                                {
                                                    <img src="@logoPath"
                                                         alt="@displayBrand Logo"
                                                         class="card-brand-logo" />
                                                }
                                                else
                                                {
                                                    <i class="bi bi-credit-card-2-front fs-2 text-primary"></i>
                                                }

                                                <span class="card-brand-name">@displayBrand</span>
                                            </div>

                                            <div class="card-info">
                                                <div class="card-number">@card.MaskedCardNumber</div>
                                                <div class="card-holder">@card.CardHolderName</div>
                                                <div class="card-expiry">Expires: @card.ExpiryDate</div>
                                                <div class="card-status active-status">Active</div>
                                            </div>
                                        </div>
                                    </label>
                                }
                            }

                        </div>
                    }
                    else
                    {
                        <div class="empty-payment-state">
                            <i class="bi bi-credit-card-2-front"></i>
                            <h4>No saved card yet</h4>
                            <p>Add a card first, or choose cash payment.</p>
                        </div>
                    }

                    <!-- Online Rental Agreement Confirmation -->
                    <div class="online-agreement-box mt-4">
                        <h5>Online Rental Agreement</h5>

                        <p>
                            By completing this booking, I confirm that the information I provided is true and correct.
                            I agree to return the vehicle on the selected return date and time, accept responsibility for
                            damages, late returns, penalties, and understand that this booking is still subject to admin approval.
                        </p>

                        <label class="agreement-check">
                            <input asp-for="AgreementAccepted" type="checkbox" />
                            <span>I have read and agree to the rental agreement.</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary complete-booking-btn">
                        Complete Booking
                    </button>

                </form>
            }

        </section>

    </main>
</div>

<!-- Reusable Add Payment Method Modal -->
@await Html.PartialAsync("/Pages/User/Payments/_AddPaymentModal.cshtml")

@section Scripts {
    <script>
        /*
            When a saved card is selected, the Cash option is unchecked.
            This lets the backend know that the user selected a card payment.
        */
        function selectSavedCard() {
            const cashRadio = document.querySelector('input[name="SelectedPaymentType"][value="Cash"]');

            if (cashRadio) {
                cashRadio.checked = false;
            }
        }

        /*
            When Cash is selected, any selected saved card is cleared.
        */
        function clearSelectedCard() {
            const selectedCards = document.querySelectorAll('input[name="SelectedSavedCardId"]');

            selectedCards.forEach(function (card) {
                card.checked = false;
            });
        }
    </script>
}