@page
@model VentureCarRentals.Pages.LoginModel
@{
    ViewData["Title"] = "Log In";
    ViewData["HideNavbar"] = true;
}

<div class="row g-0 min-vh-100">

    <!-- LEFT: BRAND SIDE -->
    <div class="col-md-7 brand-side position-relative">
        <a href="/" class="back-home-btn position-absolute top-0 start-0 m-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
            </svg>
        </a>
        <img src="~/images/logo.png" class="brand-logo" alt="V Car Rentals Logo" />
        <p class="brand-name">Car Rentals</p>
    </div>

    <!-- RIGHT: FORM SIDE -->
    <div class="col-md-5 form-side form-side-right">
        <div class="mobile-brand">
            <img src="/images/logo.png" class="brand-logo" alt="Logo" />
            <span class="brand-name">Car Rentals</span>
        </div>
        <div class="auth-card auth-card-right">
            <h2>Log-in</h2>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input type="email" name="Email" class="form-control" placeholder="Email address" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-icon-wrapper">
                        <input type="password" name="Password" id="loginPassword" class="form-control" placeholder="Password" required />
                        <button type="button" class="eye-icon" onclick="togglePassword('loginPassword')">&#128065;</button>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 mb-3">Log in</button>
            </form>
            <div class="divider-or">OR</div>
            <p class="text-center mb-0 small">
                Don't have an account? <a href="/Register" class="text-primary fw-semibold">Sign Up</a>
            </p>
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <p class="auth-message text-danger mt-3">@Model.Message</p>
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function togglePassword(id) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}
